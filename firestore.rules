rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user's enterprise ID
    function getEnterpriseId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.enterprise_id;
    }

    // User profiles - anyone authenticated can read their own or create their one
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Global settings - anyone authenticated can read
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    // Scoped Collections (Invoices, Customers, etc.)
    // We match any document in these collections and check for enterprise_id mapping
    match /{collectionName}/{docId} {
      allow read, write: if isSignedIn() && (
        // Allow if the resource doesn't exist (creating new) or if it matches the user's enterprise
        (resource == null && request.resource.data.enterprise_id == getEnterpriseId()) ||
        (resource != null && resource.data.enterprise_id == getEnterpriseId())
      );
    }
  }
}
