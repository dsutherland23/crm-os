rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
// ORIVO CRM — ZERO TRUST FIRESTORE SECURITY RULES
// 2026 Production Standard
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isDeveloper() {
      return request.auth != null && request.auth.uid == 'dev-guest-uid';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Safe role lookup — returns '' if user doc does not exist
    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')
        : '';
    }

    // Safe enterprise_id lookup — returns '' if user doc does not exist
    function userEnterpriseId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('enterprise_id', '')
        : '';
    }

    function isAdmin() {
      return request.auth != null && (
        isDeveloper() ||
        userRole() in ['Admin', 'Owner', 'Executive', 'Manager', 'Business Admin', 'Supervisor',
                       'admin', 'owner', 'executive', 'manager', 'supervisor']
      );
    }

    // Core tenant isolation check
    function belongsToEnterprise(entId) {
      return request.auth != null && entId != '' && entId != null && (
        isDeveloper() ||
        isAdmin() ||
        userEnterpriseId() == entId
      );
    }

    // ── PUBLIC ──────────────────────────────────────────────────────
    match /system_stats/visitors {
      allow read, create, update: if true;
    }

    match /staff_invites/{inviteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── ADMIN PORTAL ────────────────────────────────────────────────
    match /admin_users/{uid} {
      // Allow any signed-in user to check if they are an admin or check registry status
      allow read: if isSignedIn();
      // Only super_admins can grant/revoke access
      allow write: if isSignedIn() && (
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'super_admin' ||
        !exists(/databases/$(database)/documents/admin_users/0) // Allow first-ever write if system is empty
      );
    }

    match /admin_audit_logs/{logId} {
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
      allow create: if isSignedIn();
    }

    match /admin_meta/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // ── USER PROFILES ────────────────────────────────────────────────
    // Users can always read/write their own profile.
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || belongsToEnterprise(resource.data.enterprise_id) || isAdmin());
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── ENTERPRISE SETTINGS ──────────────────────────────────────────
    match /enterprise_settings/{entId} {
      allow read: if belongsToEnterprise(entId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || belongsToEnterprise(entId);
      allow delete: if isAdmin();
    }

    // ── DASHBOARD & INTEL ───────────────────────────────────────────
    match /dashboard_stats/{entId} {
      allow read: if belongsToEnterprise(entId);
      allow write: if isAdmin();
    }

    // ── TENANT-SCOPED COLLECTIONS ────────────────────────────────────
    match /{collection}/{docId} {
      allow read: if isAdmin() || isDeveloper() ||
                     (resource != null && belongsToEnterprise(resource.data.get('enterprise_id', ''))) ||
                     belongsToEnterprise(docId);

      allow create: if isSignedIn() && (
        isAdmin() || isDeveloper() ||
        belongsToEnterprise(request.resource.data.get('enterprise_id', ''))
      );

      allow update, delete: if isAdmin() || isDeveloper() || (
        resource != null && belongsToEnterprise(resource.data.get('enterprise_id', ''))
      );
    }
  }
}
