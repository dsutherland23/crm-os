rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
// ORIVO CRM — ZERO TRUST FIRESTORE SECURITY RULES
// 2026 Production Standard
// 
// Security Model:
//   1. Deny ALL by default — nothing is open unless explicitly granted
//   2. Tenant isolation — users can ONLY access their own enterprise_id data
//   3. Admin access — scoped to admin_users collection membership + custom claims
//   4. Audit logs — write-only from clients, never readable by tenants
//   5. Admin meta — super_admin only
// 
// Red Team Scenarios Addressed:
//   ❌ Tenant A reading Tenant B data → blocked by enterprise_id check
//   ❌ tenant_user accessing /admin_users → blocked by isAdmin() check
//   ❌ Client escalating own role → users/{uid} role field is read/write by owner,
//        but role assignment for admin claims happens only via Cloud Functions
//   ❌ Client writing to audit logs as someone else → admin_uid is set server-side
//        in Cloud Functions; client writes are restricted to own uid
//   ❌ Anyone reading other users' profiles → blocked by uid match rule
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──────────────────────────────────────────────

    // Is the request authenticated at all?
    function isSignedIn() {
      return request.auth != null;
    }

    // Does the user's JWT have a valid admin role claim?
    function hasAdminClaim() {
      return isSignedIn() &&
        request.auth.token.get('role', '') in ['admin', 'super_admin'];
    }

    // Does the user exist in the admin_users collection?
    // This is the fallback for environments before Cloud Functions are deployed.
    function isAdminUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Combined admin check (claims OR admin_users membership)
    function isAdmin() {
      return hasAdminClaim() || isAdminUser();
    }

    // Does the requesting user own this specific document?
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Does the user belong to the given enterprise?
    function belongsToEnterprise(enterpriseId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.enterprise_id == enterpriseId;
    }

    // Is the document's enterprise_id the same as the requester's?
    function isOwnEnterprise() {
      return isSignedIn() &&
        resource.data.enterprise_id ==
          get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.enterprise_id;
    }

    // Is the new document being written to the requester's enterprise?
    function isOwnEnterpriseWrite() {
      return isSignedIn() &&
        request.resource.data.enterprise_id ==
          get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.enterprise_id;
    }

    // ── COLLECTION RULES ──────────────────────────────────────────────

    // ─── User Profiles ────────────────────────────────────────────────
    // Each user can only read/write their OWN profile.
    // Admins can read all, but CANNOT write (role changes go through Cloud Functions).
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Users can update their own profile EXCEPT the role and status fields
      allow update: if isOwner(userId) &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('enterprise_id' in request.resource.data.diff(resource.data).affectedKeys());
      // Initial profile create is allowed on signup (before any profile exists)
      allow create: if isOwner(userId);
      // Deletes require admin
      allow delete: if isAdmin();
    }

    // ─── Enterprise Settings ──────────────────────────────────────────
    // Members can read their own enterprise settings.
    // Only admins can write to non-own enterprise settings.
    match /enterprise_settings/{enterpriseId} {
      allow read: if isSignedIn() && (
        belongsToEnterprise(enterpriseId) || isAdmin()
      );
      // Members can update their OWN enterprise settings (non-critical fields)
      allow update: if isSignedIn() &&
        belongsToEnterprise(enterpriseId) &&
        !('status' in request.resource.data.diff(resource.data).affectedKeys());
      // Only admins can change status (suspend/activate)
      allow update: if isAdmin();
      // Signup provisioning — allow create if the data references the creator's uid
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Admin Users Registry ─────────────────────────────────────────
    // ONLY super_admin can read or write this collection.
    // No tenant user should ever see this.
    match /admin_users/{adminId} {
      allow read, write: if hasAdminClaim() &&
        request.auth.token.role == 'super_admin';
    }

    // ─── Admin Audit Logs ─────────────────────────────────────────────
    // IMMUTABLE: Tenants cannot read. Admins can read. 
    // Client-side creates are allowed (with own uid as admin_uid).
    // Nobody can update or delete.
    match /admin_audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.admin_uid == request.auth.uid;
      allow update, delete: if false; // IMMUTABLE
    }

    // ─── Admin Meta / Feature Flags ──────────────────────────────────
    // Only super_admin can modify. Admins can read.
    match /admin_meta/{docId} {
      allow read: if isAdmin();
      allow write: if hasAdminClaim() &&
        request.auth.token.role == 'super_admin';
    }

    // ─── Tenant-Scoped Collections ────────────────────────────────────
    // Every document in these collections MUST have an enterprise_id field.
    // Users can only access documents matching their own enterprise_id.
    // Admins have read-only cross-tenant access.
    match /{collection}/{docId} {
      // Adminread-only across tenants
      allow read: if isAdmin();

      // Regular tenant access — must match own enterprise
      allow read: if isSignedIn() &&
        resource != null &&
        resource.data.enterprise_id != null &&
        isOwnEnterprise();

      // Writes must target own enterprise
      allow create: if isSignedIn() &&
        request.resource.data.enterprise_id != null &&
        isOwnEnterpriseWrite();

      allow update: if isSignedIn() &&
        resource != null &&
        resource.data.enterprise_id != null &&
        isOwnEnterprise() &&
        // enterprise_id cannot be changed
        request.resource.data.enterprise_id == resource.data.enterprise_id;

      allow delete: if isSignedIn() &&
        resource != null &&
        resource.data.enterprise_id != null &&
        isOwnEnterprise();
    }
  }
}
