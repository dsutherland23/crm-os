rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
// ORIVO CRM — ZERO TRUST FIRESTORE SECURITY RULES
// 2026 Production Standard
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isDeveloper() {
      return request.auth != null && request.auth.uid == 'dev-guest-uid';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Safe role lookup — returns '' if user doc does not exist
    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')
        : '';
    }

    // Safe enterprise_id lookup — returns '' if user doc does not exist
    function userEnterpriseId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('enterprise_id', '')
        : '';
    }

    function isAdmin() {
      return request.auth != null && (
        isDeveloper() ||
        userRole() in ['Admin', 'Owner', 'Executive', 'Manager', 'Business Admin', 'Supervisor',
                       'admin', 'owner', 'executive', 'manager', 'supervisor']
      );
    }

    // Core tenant isolation check
    function belongsToEnterprise(entId) {
      return request.auth != null && entId != '' && entId != null && (
        isDeveloper() ||
        isAdmin() ||
        userEnterpriseId() == entId
      );
    }

    // ── PUBLIC ──────────────────────────────────────────────────────
    match /system_stats/visitors {
      allow read, create, update: if true;
    }

    match /staff_invites/{inviteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── USER PROFILES ────────────────────────────────────────────────
    // Users can always read/write their own profile.
    // Needed for first-time setup and self-repair flows.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── ENTERPRISE SETTINGS ──────────────────────────────────────────
    // Keyed by enterpriseId. Any signed-in user can create (first-time setup).
    match /enterprise_settings/{entId} {
      allow read: if belongsToEnterprise(entId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || belongsToEnterprise(entId);
      allow delete: if isAdmin();
    }

    // ── LOYALTY SETTINGS ────────────────────────────────────────────
    // Keyed by enterpriseId. Read is allowed if:
    //  a) user is an admin/developer, OR
    //  b) the user's enterprise_id matches the doc ID
    // We also allow create for signed-in users (first-time setup)
    match /loyalty_settings/{entId} {
      allow read: if belongsToEnterprise(entId);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || belongsToEnterprise(entId);
    }

    match /settings/{entId} {
      allow read: if belongsToEnterprise(entId);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || belongsToEnterprise(entId);
    }

    // ── TENANT-SCOPED COLLECTIONS ────────────────────────────────────
    // Generic catch-all for all other collections.
    match /{collection}/{docId} {
      allow read: if isAdmin() || isDeveloper() ||
                     belongsToEnterprise(resource.data.get('enterprise_id', '')) ||
                     belongsToEnterprise(docId);

      allow create: if isSignedIn() && (
        isAdmin() || isDeveloper() ||
        request.resource.data.get('enterprise_id', '') == userEnterpriseId()
      );

      allow update, delete: if isAdmin() || isDeveloper() || (
        isSignedIn() &&
        resource.data.get('enterprise_id', '') == userEnterpriseId()
      );
    }
  }
}
