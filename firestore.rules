rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user's enterprise ID
    // We use a safe get that handles missing documents during signup
    function getEnterpriseId() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.enterprise_id : null;
    }

    // User profiles - anyone authenticated can read their own or create their one
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Enterprise Settings - scoped by the setting document ID (which is the enterprise ID)
    match /enterprise_settings/{enterpriseId} {
      allow read, write: if isSignedIn();
    }

    // Scoped Data Collections
    // These collections are strictly partitioned by enterprise_id
    match /{collectionName}/{docId} {
      allow read, write: if isSignedIn() && (
        // Skip check for global/meta collections
        collectionName in ['users', 'enterprise_settings', 'settings', 'notifications'] ||
        // Check enterprise isolation for everything else
        (resource == null && request.resource.data.enterprise_id == getEnterpriseId()) ||
        (resource != null && resource.data.enterprise_id == getEnterpriseId())
      );
    }
    
    // Notifications special handling (allows creation by system/anyone but read only by enterprise)
    match /notifications/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        resource.data.enterprise_id == getEnterpriseId()
      );
    }
  }
}
