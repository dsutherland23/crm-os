rules_version = '2';

// Targeted Rules for AI Studio Database
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Enterprise Settings
    match /enterprise_settings/{enterpriseId} {
      allow read, write: if isSignedIn();
    }

    // Scoped Data Collections
    match /{collectionName}/{docId} {
      // Allow access to meta collections
      allow read, write: if isSignedIn() && collectionName in ['users', 'enterprise_settings', 'settings', 'notifications'];
      
      // Allow access to scoped collections if enterpriseId matches
      allow read, write: if isSignedIn() && !(collectionName in ['users', 'enterprise_settings', 'settings', 'notifications']) && (
        (resource == null && request.resource.data.enterprise_id != null) ||
        (resource != null && resource.data.enterprise_id != null)
      );
    }
  }
}
